# WhatWatchBot Credentials

# [Required for search results] The Movie Database (TMDB)
TMDB_API_KEY=your_tmdb_api_key_here

# [Required for RT ratings] Open Movie Database (OMDB)
OMDB_API_KEY=your_omdb_api_key_here

# [Required for trailers] YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Your contact URL (used in Wikipedia API User-Agent header, required by Wikipedia policy)
# Use your GitHub repo URL or a personal website URL
CONTACT_URL=https://github.com/your-username

