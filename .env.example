# WhatWatchBot Credentials

# [Obbligatorio per risultati ricerca] The Movie Database (TMDB)
TMDB_API_KEY=your_tmdb_api_key_here

# [Obbligatorio per rating RT] Open Movie Database (OMDB)
OMDB_API_KEY=your_omdb_api_key_here

# [Obbligatorio per trailer] YouTube Data API v3
YOUTUBE_API_KEY=your_youtube_api_key_here

# Preferenze globali
RT_MIN_SCORE=70
LANGUAGE=it-IT
REGION=IT
